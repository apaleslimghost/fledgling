		"@react-router/serve": "^7.0.0",
		"@rvf/react": "^8.1.1",
		"@rvf/react-router": "^8.1.1",
		"@rvf/zod": "^7.0.4",
		"@tiptap/extension-document": "^3.22.2",
		"@tiptap/extension-mention": "^3.22.2",
		"@tiptap/extensions": "^3.22.2",
		"@tiptap/html": "^3.22.2",
		"@tiptap/pm": "^3.22.2",
		"@tiptap/react": "^3.22.2",
		"@tiptap/starter-kit": "^3.22.2",
		"@tiptap/suggestion": "^3.22.2",
		"lodash": "^4.17.21",
		"minisearch": "^7.2.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.0.0",
		"rxdb": "^17.1.0",
		"tailwindcss": "^4.2.2",
		"tippy.js": "^6.3.7",
		"zod": "^4.3.6",
		"isbot": "^5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@react-router/dev": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/lodash": "^4.17.13",
		"@types/node": "^24.12.2",
		"@types/react": "^18.2.20",
		"@types/react-dom": "^18.2.7",
		"@typescript-eslint/eslint-plugin": "^6.7.4",
		"@typescript-eslint/parser": "^6.7.4",
		"lint-staged": "^16.4.0",
		"patch-package": "^8.0.1",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^5.1.6",
		"vite": "^5.1.0",
		"vite-tsconfig-paths": "^4.2.1"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"volta": {
		"node": "24.14.1"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json}": "biome check --write --no-errors-on-unmatched"
	}
